params {
    samplesheet = "/path/to/samplesheet.csv"
    ref_genome = "/path/to/mm10.fa"
    gtf = "/path/to/mm10.refGene.gtf"
    fa_dict = null
    star_index = null
    snpeff_db  = null
    lncRNAs_ref = "/path/to/lnc_only.gtf"
    known_snps_vcf = "/path/to/known_snps.vcf.gz"
    control_cnt = 60        // take the number of control samples and multiply by 10

    // Define groups here (do not let them end in a number)
    group1 = "Control"
    group2 = "TreatmentA"
    group3 = "TreatmentB"

    outdir = "$projectDir/results/"
}

profiles {
    conda {
        conda.enabled = true
    }
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
    }
    cluster {
        process {
                executor = 'sge'
                clusterOptions = '-P <lab_key>'
                penv = 'omp'

                withLabel: process_single {
                    cpus   = 1
                    memory = '4 GB'
                }

                withLabel: process_two {
                    cpus   = 2
                    memory = '8 GB'
                }

                withLabel: process_low {
                    cpus   = 4
                    memory = '16 GB'
                }

                withLabel: process_medium {
                    cpus   = 8
                    memory = '32 GB'
                }

                withLabel: process_high {
                    cpus   = 16
                    memory = '64 GB'
                }
        }
    }

    local {
        process.executor = 'local'
    }
}

//Change the queueSize to enable more parallel jobs (remember the SCC is a shared resource)
// queueSize is higher now to accommodate per-chromosome VarScan jobs
// (18 experimental samples x ~21 chromosomes = ~378 jobs)
executor {
    $sge {
        queueSize = 100
    }
    $local {
        cpus = 1
    }
}

resume = true

// Automatically remove work/ directory contents after a successful run.
// WARNING: this disables -resume for subsequent runs. Comment out if you
// need to restart a failed run from a checkpoint.
cleanup = true
